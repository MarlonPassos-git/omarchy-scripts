#!/usr/bin/env bash
set -euo pipefail

load_screenshot_directory() {
  # Omarchy users can override screenshot targets without editing this script.
  [[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs
  printf '%s\n' "${OMARCHY_SCREENSHOT_DIR:-${XDG_PICTURES_DIR:-$HOME/Pictures}}"
}

active_window_geometry() {
  local geometry
  geometry=$(hyprctl activewindow -j | jq -er '
    if (.at | type == "array") and (.size | type == "array") then
      "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"
    else
      error("activewindow must include at:[x,y] and size:[w,h]")
    end
  ')
  printf '%s\n' "$geometry"
}

save_active_window_screenshot() {
  local output_dir="$1"
  local geometry="$2"
  local filepath="$output_dir/screenshot-$(date +'%Y-%m-%d_%H-%M-%S').png"

  mkdir -p "$output_dir"
  grim -g "$geometry" "$filepath"
  # Screenshot workflows usually need immediate paste into chat or docs.
  wl-copy <"$filepath"
  printf '%s\n' "$filepath"
}

open_screenshot_preview() {
  local filepath="$1"
  local viewer

  viewer=$(screenshot_preview_command) || return 0
  "$viewer" "$filepath" >/dev/null 2>&1 &
}

screenshot_preview_command() {
  if command -v imv >/dev/null; then
    printf 'imv\n'
    return
  fi

  command -v xdg-open >/dev/null && printf 'xdg-open\n'
}

display_path() {
  local filepath="$1"
  local home_prefix="$HOME/"

  if [[ $filepath == "$home_prefix"* ]]; then
    printf '~/%s\n' "${filepath#"$home_prefix"}"
    return
  fi

  printf '%s\n' "$filepath"
}

main() {
  local output_dir geometry filepath notification_path

  output_dir=$(load_screenshot_directory)
  geometry=$(active_window_geometry)
  filepath=$(save_active_window_screenshot "$output_dir" "$geometry")
  notification_path=$(display_path "$filepath")
  open_screenshot_preview "$filepath"
  notify-send "Active window screenshot saved" "$notification_path" -t 3000 -i "$filepath"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
